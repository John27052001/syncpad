# Required: PostgreSQL connection string.
# - Docker: use postgres/postgres or the user you created
# - Local Mac (Homebrew/Postgres.app): often your system user, no password:
#   postgresql://YOUR_MAC_USERNAME@localhost:5432/syncpad?schema=public
DATABASE_URL="postgresql://user:password@localhost:5432/syncpad?schema=public"

PORT=4000
FRONTEND_URL="http://localhost:3000"
